{
  "manifest_version": 3,
  "name": "frago bridge",
  "version": "0.1.0",
  "description": "frago agent OS \u2014 browser bridge (MVP P1).",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content_script.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "frago bridge"
  }
}
