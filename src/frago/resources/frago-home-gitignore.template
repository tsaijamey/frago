# ~/.frago gitignore template
# 此文件是 ~/.frago/.gitignore 的权威模板
# 由 sync_repo.py:_ensure_gitignore() 在 frago sync 时写入
#
# 往 ~/.frago/ 新增文件时，MUST 判断是否加到这里：
#   设备本地运行时产物（cache、state、log、pid）→ 加
#   跨设备共享资源（recipes/、定义文件）→ 不加

# Runtime data (not synced)
sessions/
sessions.json
executions/
ingested_tasks.json
message_cache.json
traces/
threads/
chrome_profile/
chrome_profile_*/
edge_profile/
edge_profile_*/
chrome/extension-profile/
current_run
projects/.tmp/
projects/**/screenshots/
projects/**/logs/
# Run instance binary/cache artifacts under both legacy projects/{session}/...
# and domain layout projects/{domain}/{session}/... (commit 1a66bc7).
# metadata.json / steps.jsonl / summary.{json,md} / _domain.json / insights/
# are still synced as text-only run state.
projects/**/chrome_profile/
projects/**/chrome_profile_*/
projects/**/chrome_profile2/
projects/**/temp/
projects/**/outputs/
projects/**/.cache/
projects/**/.git/
runtime.json
runtime.json.bak.*

# Cache directories (device-local, not synced)
cache/

# Commands directory (managed by frago itself, not synced)
.claude/commands/

# Local metadata (device-specific, not synced)
.claude/skills_metadata.json
.claude/sync_metadata.json
.claude/settings.local.json
.device_id
.workspace_migrated
.api_endpoint_migrated
.cache/

# Config files (contain sensitive information or device-specific)
config.json
gui_config.json
profiles.json
recipes.local.json

# Environment variable files (sensitive information)
.env
.env.*
.env.local
.env.*.local

# System files
.DS_Store
__pycache__/
*.pyc
*.bak
*.bak.*
server.pid
server.log*
gui_history.jsonl

# Conflict backup files (temporary)
*.LOCAL
*.REMOTE
*.sync-backup
*.sync-backup.local
*.sync-backup.remote

# Video files
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# Audio files
*.wav
*.mp3
*.aac
*.flac
*.ogg
*.m4a

# Log files
logs/
*.log

# Archives and other large files
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.pdf
*.psd
*.ai

# Recipe-scoped project runtime artifacts (not synced)
# Text state (project.json / script.md / manifest.json) under _projects/
# IS synced; only binary / cacheable artifacts below are excluded.
recipes/*/*/_projects/**/assets/
recipes/*/*/_projects/**/tts/
recipes/*/*/_projects/**/html/
recipes/*/*/_projects/**/logs/
recipes/*/*/_projects/**/*.mp4
recipes/*/*/_projects/**/*.png
recipes/*/*/_projects/**/*.jpg
recipes/*/*/_projects/**/*.jpeg
recipes/*/*/_projects/**/*.webp
recipes/*/*/_projects/**/*.wav
